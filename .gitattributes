# Normalize all text files to LF in the repository and on checkout.
# Stops the CRLF/LF churn that was marking the whole tree as modified.
* text=auto eol=lf

# Explicitly treat common binary assets as binary (never normalized).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.xlsx binary
